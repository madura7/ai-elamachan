# ElaMachan — example environment configuration.
#
# Copy to `.env` and fill in local values:  cp .env.example .env
# `.env` is git-ignored and must NEVER be committed.
#
# In deployed environments (GCP), the SECRET values below are injected from
# GCP Secret Manager — not from a committed file. See docs/secrets.md.

# ── Postgres ────────────────────────────────────────────────────────────────
POSTGRES_USER=elamachan
POSTGRES_PASSWORD=elamachan            # SECRET in prod — sourced from Secret Manager
POSTGRES_DB=elamachan
POSTGRES_PORT=5432
# Full URL used by the backend and the migrate tool:
DATABASE_URL=postgres://elamachan:elamachan@localhost:5432/elamachan?sslmode=disable

# ── Redis ───────────────────────────────────────────────────────────────────
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0

# ── Meilisearch ─────────────────────────────────────────────────────────────
MEILI_PORT=7700
MEILI_ENV=development
MEILI_MASTER_KEY=masterKey_dev_only_change_me   # SECRET in prod — Secret Manager
MEILI_URL=http://localhost:7700

# ── Auth ────────────────────────────────────────────────────────────────────
JWT_SECRET=dev_jwt_secret_change_me              # SECRET in prod — Secret Manager
SMS_MODE=dev                                     # dev = log OTPs to stdout; real delivery needs VER-44
OTP_EXPIRY_MINUTES=10                            # how long an OTP challenge stays valid

# ── Claude API (AI-assisted listings) ───────────────────────────────────────
ANTHROPIC_API_KEY=                               # SECRET — never commit; Secret Manager in prod
ANTHROPIC_MODEL=claude-sonnet-4-6                # informational; the ai-draft endpoint PINS claude-haiku-4-5 (VER-42)
AIASSIST_SPEND_CAP_CALLS=                        # optional spend cap: max billable model calls per window; empty/<=0 = no cap
AIASSIST_SPEND_CAP_WINDOW_SECONDS=               # optional refill window for the spend cap; empty/<=0 = default (3600s)

# ── App ─────────────────────────────────────────────────────────────────────
APP_ENV=development
BACKEND_PORT=8080
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080
